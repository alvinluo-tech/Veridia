# Veridia Environment Variables
# Copy this file to .env.local and fill in the values

# ── Local Mode (default) ────────────────────────────────
# Leave Supabase variables empty to use local SQLite mode.
# Demo account: demo@veridia.app / password123
# Run `npx tsx scripts/seed.ts` to populate sample data.

# ── Supabase Mode (optional) ────────────────────────────
# Fill in these to use Supabase as the database backend.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Session ─────────────────────────────────────────────
# iron-session encryption secret (min 32 characters)
# IRON_SESSION_SECRET=your-super-secret-key-at-least-32-chars
